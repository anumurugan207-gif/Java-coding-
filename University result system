class Student {
    String name;
    int[] marks;

    public Student(String name, int[] marks) {
        this.name = name;
        this.marks = marks;
    }

    public void displayResult() {
        int total = 0;
        boolean isPass = true;

        for (int score : marks) {
            total += score;
            // If even one subject is below 40, the result is Fail
            if (score < 40) {
                isPass = false;
            }
        }

        if (isPass) {
            System.out.println("Pass");
        } else {
            System.out.println("Fail");
        }
    }

    public static void main(String[] args) {
        // Input: marks = {55, 65, 70, 35}
        int[] inputMarks = {55, 65, 70, 35};
        Student student = new Student("John Doe", inputMarks);

        student.displayResult();
    }
}
