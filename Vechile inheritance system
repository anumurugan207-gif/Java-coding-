class Vehicle {
    // Parent method
    public void fuelType() {
        System.out.println("Generic Fuel");
    }
}

class Car extends Vehicle {
    // Overriding the parent method to provide specific implementation
    @Override
    public void fuelType() {
        System.out.println("Petrol");
    }
}

public class Main {
    public static void main(String[] args) {
        // Create an instance of Car
        Car myCar = new Car();
        
        // This calls the overridden method in the Car class
        myCar.fuelType();
    }
}
