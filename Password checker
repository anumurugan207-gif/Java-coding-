import java.util.Scanner;
import java.util.regex.Matcher;
import java.util.regex.Pattern;

public class PasswordChecker {

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        
        System.out.println("--- Password Security Check ---");
        System.out.print("Enter a password to validate: ");
        String password = sc.nextLine();

        if (isValid(password)) {
            System.out.println("Strong Password! Access Granted.");
        } else {
            System.out.println("Weak Password!");
            System.out.println("Requirements:");
            System.out.println("- At least 8 characters long");
            System.out.println("- Must contain at least one digit");
            System.out.println("- Must contain one uppercase and one lowercase letter");
            System.out.println("- Must contain one special character (@#$%^&+=!)");
        }
        sc.close();
    }

    public static boolean isValid(String password) {
        // Regex Breakdown:
        // ^                 Start of string
        // (?=.*[0-9])       At least one digit
        // (?=.*[a-z])       At least one lowercase letter
        // (?=.*[A-Z])       At least one uppercase letter
        // (?=.*[@#$%^&+=!]) At least one special character
        // \\S+$             No whitespace allowed
        // .{8,}             Minimum 8 characters
        String passwordPolicy = "^(?=.*[0-9])(?=.*[a-z])(?=.*[A-Z])(?=.*[@#$%^&+=!])(?=\\S+$).{8,}$";
        
        Pattern pattern = Pattern.compile(passwordPolicy);
        Matcher matcher = pattern.matcher(password);
        
        return matcher.matches();
    }
}
