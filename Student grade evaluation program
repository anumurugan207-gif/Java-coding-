import java.util.Scanner;

public class GradeEvaluator {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int[] marks = new int[5];
        int total = 0;

        // Reading 5 subject marks
        for (int i = 0; i < 5; i++) {
            marks[i] = sc.nextInt();
            total += marks[i];
        }

        // Calculating percentage (integer as requested)
        int percentage = total / 5;

        // Determining the grade
        char grade;
        if (percentage >= 90) {
            grade = 'A';
        } else if (percentage >= 75) {
            grade = 'B';
        } else if (percentage >= 60) {
            grade = 'C';
        } else {
            grade = 'F'; // "Fail" represented by 'F' or you could use a String
        }

        // Printing results in the required format
        if (grade == 'F') {
            System.out.println(total + " " + percentage + " Fail");
        } else {
            System.out.println(total + " " + percentage + " " + grade);
        }

        sc.close();
    }
}
