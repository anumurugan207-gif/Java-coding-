import java.util.Scanner;

public class TemperatureAnalyzer {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        float[] temp = new float[7];
        float sum = 0;

        // Input 7 temperatures
        System.out.println("Enter temperatures for 7 days:");
        for (int i = 0; i < 7; i++) {
            temp[i] = sc.nextFloat();
            sum += temp[i]; // Add to sum for average calculation
        }

        // Initialize high and low with the first element
        float max = temp[0];
        float min = temp[0];

        // Find High and Low
        for (int i = 1; i < 7; i++) {
            if (temp[i] > max) {
                max = temp[i];
            }
            if (temp[i] < min) {
                min = temp[i];
            }
        }

        float average = sum / 7;

        // Output: Highest, Lowest, and Average (formatted)
        System.out.print(max + " " + min + " ");
        System.out.printf("%.2f\n", average);

        sc.close();
    }
}
